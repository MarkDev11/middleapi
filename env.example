# ─────────────────────────────────────────────────────────────
# 📁 PATH: .env.local   (root project — sejajar dengan package.json)
#
# Rename file ini dari .env.example → .env.local
# JANGAN commit .env.local ke git!
# Di Vercel, set semua variable ini di:
#   Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Telegram Bot Token dari @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# URL HF Space kamu (tanpa trailing slash)
OPENCLAW_HF_URL=https://mark421-openclaw-ai.hf.space

# Sama dengan env var OPENCLAW_GATEWAY_PASSWORD yang kamu set di HF Space
OPENCLAW_GATEWAY_PASSWORD=your_gateway_password_here

# Agent ID yang mau dipake (default: main)
OPENCLAW_AGENT_ID=main

# Untuk protect endpoint /api/telegram/setup
# Buat string random, contoh: openssl rand -hex 16
SETUP_SECRET=your_random_setup_secret

# Untuk local dev: URL deploy kamu di Vercel
# Di production, Vercel otomatis inject VERCEL_URL
VERCEL_URL=https://your-project.vercel.app
